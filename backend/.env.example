FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=the-super-secret-key-change-in-production

# Database
DATABASE_URL=postgresql://skinnovate_user:password@localhost:5432/skinnovate_db

# JWT
JWT_SECRET_KEY=the-jwt-super-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# File Upload
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# AI Model
AI_MODEL_PATH=app/services/ai_service/model/skin_model.keras
AI_CONFIDENCE_THRESHOLD=0.70

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
